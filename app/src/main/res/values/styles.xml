<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.BankingApp.CleanTextView" parent="@android:style/Widget.TextView">
        <item name="android:shadowColor">@android:color/transparent</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">0</item>
        <item name="android:elegantTextHeight">false</item>
    </style>

    <style name="Widget.BankingApp.CleanTextViewCompat" parent="Widget.AppCompat.TextView">
        <item name="android:shadowColor">@android:color/transparent</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">0</item>
        <item name="android:elegantTextHeight">false</item>
    </style>

    <style name="Widget.BankingApp.CleanEditText" parent="@android:style/Widget.EditText">
        <item name="android:shadowColor">@android:color/transparent</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">0</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <style name="Widget.BankingApp.CleanEditTextCompat" parent="Widget.AppCompat.EditText">
        <item name="android:shadowColor">@android:color/transparent</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">0</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <style name="Widget.BankingApp.CleanButton" parent="Widget.Material3.Button">
        <item name="android:shadowColor">@android:color/transparent</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">0</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.BankingApp.CleanButtonCompat" parent="Widget.AppCompat.Button">
        <item name="android:shadowColor">@android:color/transparent</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">0</item>
        <item name="textAllCaps">false</item>
    </style>
</resources>
